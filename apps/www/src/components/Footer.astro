---
// Footer
const year = new Date().getFullYear();
---

<footer class="border-t border-border-dark bg-bg-dark py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <!-- Branding -->
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-fg-muted-dark">verified_user</span>
        <span class="text-sm font-medium text-fg-muted-dark">© {year} Prove</span>
      </div>

      <!-- Links -->
      <div class="flex gap-6">
        <a
          class="text-sm text-fg-muted-dark transition-colors hover:text-white"
          href="https://twitter.com/monawwarx"
          target="_blank"
          rel="noopener noreferrer"
        >
          X/Twitter
        </a>
        <a
          class="text-sm text-fg-muted-dark transition-colors hover:text-white"
          href="https://github.com/mxvsh/prove"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
