---
// TransformSection — before/after "From Chaos to Clarity" cards
---

<section class="border-t border-border-dark bg-bg-dark py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="font-display text-4xl font-medium tracking-tight text-white sm:text-5xl">
        From Chaos to Clarity
      </h2>
      <p class="mt-4 text-lg text-fg-muted-dark">
        Watch your messy brain dumps transform into actionable business plans
        instantly.
      </p>
    </div>

    <div class="relative grid gap-8 lg:grid-cols-2 lg:gap-12">
      <!-- Before card -->
      <div
        class="relative overflow-hidden rounded-2xl border border-border-dark bg-surface-dark/50 p-8 backdrop-blur-sm transition-transform hover:-translate-y-1"
      >
        <div
          class="mb-6 flex items-center gap-3 border-b border-border-dark pb-4"
        >
          <div
            class="flex h-10 w-10 items-center justify-center rounded-full bg-danger-light text-danger"
          >
            <span class="material-symbols-outlined">storm</span>
          </div>
          <div>
            <h3 class="font-display text-xl font-semibold text-white">The Spark</h3>
            <p class="text-sm text-fg-muted-dark">Raw, unorganized thoughts</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="h-2 w-3/4 rounded bg-border-dark"></div>
          <div class="h-2 w-full rounded bg-border-dark"></div>
          <div class="h-2 w-5/6 rounded bg-border-dark"></div>
          <div class="h-2 w-4/5 rounded bg-border-dark"></div>
          <div class="mt-6 flex flex-wrap gap-2 opacity-50">
            <span
              class="inline-block rounded-full border border-border-dark px-3 py-1 text-xs text-fg-muted-dark"
            >
              Idea?
            </span>
            <span
              class="inline-block rounded-full border border-border-dark px-3 py-1 text-xs text-fg-muted-dark"
            >
              Users??
            </span>
            <span
              class="inline-block rounded-full border border-border-dark px-3 py-1 text-xs text-fg-muted-dark"
            >
              Revenue model undefined
            </span>
          </div>
        </div>

        <!-- Placeholder illustration -->
        <div class="mt-8 aspect-video w-full overflow-hidden rounded-lg bg-surface-dark relative">
          <div
            class="absolute inset-0 bg-gradient-to-tr from-surface-dark via-border-dark to-surface-dark opacity-50"
          ></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span
              class="material-symbols-outlined text-6xl text-border-dark opacity-50"
            >
              blur_on
            </span>
          </div>
        </div>
      </div>

      <!-- Arrow (desktop only) -->
      <div
        class="absolute left-1/2 top-1/2 z-10 hidden -translate-x-1/2 -translate-y-1/2 transform lg:block"
      >
        <div
          class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white shadow-xl shadow-primary/20"
        >
          <span class="material-symbols-outlined">arrow_forward</span>
        </div>
      </div>

      <!-- After card -->
      <div
        class="relative overflow-hidden rounded-2xl border border-primary/20 bg-surface-dark p-8 shadow-2xl shadow-primary/5 transition-transform hover:-translate-y-1"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent"
        ></div>

        <div
          class="mb-6 flex items-center gap-3 border-b border-border-dark pb-4"
        >
          <div
            class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-light text-primary"
          >
            <span class="material-symbols-outlined">auto_awesome</span>
          </div>
          <div>
            <h3 class="font-display text-xl font-semibold text-white">The Strategy</h3>
            <p class="text-sm text-fg-muted-dark">AI-synthesized roadmap</p>
          </div>
        </div>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="mt-1 h-2 w-2 shrink-0 rounded-full bg-primary"></div>
            <div class="flex-1 space-y-2">
              <div class="h-4 w-1/3 rounded bg-border-dark/50"></div>
              <p class="text-sm text-fg-muted-dark">
                Target audience identified as remote-first enterprise teams
                seeking asynchronous collaboration tools.
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="mt-1 h-2 w-2 shrink-0 rounded-full bg-primary"></div>
            <div class="flex-1 space-y-2">
              <div class="h-4 w-1/4 rounded bg-border-dark/50"></div>
              <p class="text-sm text-fg-muted-dark">
                Primary revenue stream via tiered SaaS subscription model with
                enterprise licensing.
              </p>
            </div>
          </div>
        </div>

        <!-- Abstract chart illustration -->
        <div
          class="mt-8 aspect-video w-full overflow-hidden rounded-lg bg-surface-dark relative"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-surface-dark to-primary/10"
          ></div>
          <div
            class="absolute bottom-0 left-0 right-0 flex h-3/4 items-end justify-between gap-2 px-6"
          >
            <div class="h-[30%] w-full rounded-t-sm bg-primary/20"></div>
            <div class="h-[50%] w-full rounded-t-sm bg-primary/30"></div>
            <div class="h-[40%] w-full rounded-t-sm bg-primary/40"></div>
            <div class="h-[75%] w-full rounded-t-sm bg-primary/60"></div>
            <div
              class="relative h-[90%] w-full rounded-t-sm bg-primary shadow-[0_0_15px_rgba(25,110,230,0.5)]"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
